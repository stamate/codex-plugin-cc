{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "persona",
    "recommendation",
    "impact_score",
    "summary",
    "strengths",
    "weaknesses",
    "criterion_scores",
    "findings",
    "budget_assessment",
    "timeline_assessment",
    "risk_assessment",
    "recommendations_for_revision",
    "scores"
  ],
  "properties": {
    "persona": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "enum": ["fund", "fund-with-revisions", "revise-and-resubmit", "do-not-fund"]
    },
    "impact_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "weaknesses": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "criterion_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["significance", "innovation", "approach", "investigator", "environment"],
      "properties": {
        "significance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 9 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "innovation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 9 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "approach": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 9 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "investigator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 9 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "rationale"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 9 },
            "rationale": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "severity", "title", "body", "section", "confidence", "recommendation"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["significance", "innovation", "approach", "investigator", "environment", "budget", "timeline", "compliance", "ethics"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "suggestion"]
          },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "section": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "recommendation": { "type": "string" }
        }
      }
    },
    "budget_assessment": {
      "type": "string",
      "minLength": 1
    },
    "timeline_assessment": {
      "type": "string",
      "minLength": 1
    },
    "risk_assessment": {
      "type": "string",
      "minLength": 1
    },
    "recommendations_for_revision": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["significance", "innovation", "approach", "investigator", "environment", "overall", "confidence"],
      "properties": {
        "significance": { "type": "integer", "minimum": 1, "maximum": 9 },
        "innovation": { "type": "integer", "minimum": 1, "maximum": 9 },
        "approach": { "type": "integer", "minimum": 1, "maximum": 9 },
        "investigator": { "type": "integer", "minimum": 1, "maximum": 9 },
        "environment": { "type": "integer", "minimum": 1, "maximum": 9 },
        "overall": { "type": "integer", "minimum": 1, "maximum": 9 },
        "confidence": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
